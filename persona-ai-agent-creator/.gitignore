# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/data/test-*.sqlite
/data/test-*.sqlite-wal
/data/test-*.sqlite-shm
/generated-test/

# next.js
/.next/
/out/

# production
/build

# generated build artifacts (regenerated from DB on publish)
/generated

# Tailwind CSS output (generated from app.css via build:css)
public/css/output.css

# user uploaded files
/uploads

# sqlite databases (environment-specific data)
/data

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
