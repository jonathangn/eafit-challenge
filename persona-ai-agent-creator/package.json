{
  "name": "persona-studio",
  "version": "1.0.0",
  "description": "Persona Studio MVP for EAFIT challenge",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -n css,node \"pnpm dev:css\" \"nodemon src/server.js\"",
    "start": "node src/server.js",
    "build:css": "tailwindcss -i public/css/app.css -o public/css/output.css --minify",
    "dev:css": "tailwindcss -i public/css/app.css -o public/css/output.css --watch",
    "check": "node --check src/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "slugify": "^1.6.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vitest": "^4.1.6"
  }
}
