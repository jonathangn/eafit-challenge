<div id="restore-toast" class="fixed top-24 right-4 md:right-8 z-[100] transition-all duration-500 translate-x-0 opacity-0 pointer-events-none" role="alert">
    <div class="glass-modal bg-surface/90 px-5 py-3 rounded-2xl flex items-center gap-3 border-primary/20 shadow-2xl shadow-primary/10 max-w-[calc(100vw-2rem)] md:max-w-none">
        <span class="material-symbols-outlined text-primary shrink-0">restore</span>
        <span class="font-label-md text-label-md text-on-surface"><%= t('form.restoreMessage') %></span>
    </div>
</div>

<div class="px-margin-mobile py-stack-md pb-36">
    <!-- Progress Stepper Sentinel (to safely cache document-relative top position without scroll-bound layout queries) -->
    <div id="stepper-sentinel" class="h-0 -mb-0" aria-hidden="true"></div>
    <div class="max-w-xl mx-auto mb-10 space-y-base sticky top-24 z-30 glass-bar rounded-2xl px-4 py-3" id="stepper-card">
        <!-- Outward Fillets for Stuck Header Banner Effect -->
        <div class="stepper-fillet-left" aria-hidden="true"></div>
        <div class="stepper-fillet-right" aria-hidden="true"></div>
        <div class="flex justify-between items-center px-1">
            <span class="font-label-sm text-label-sm text-on-surface-variant" id="step-count"><%= t('form.stepOf').replace('{0}', '1').replace('{1}', '3') %></span>
            <span class="font-label-sm text-label-sm text-primary font-bold uppercase tracking-widest" id="step-title"><%= t('form.step1Title') %></span>
        </div>
        <div class="h-1.5 bg-surface-container rounded-full overflow-hidden flex gap-1">
            <div class="h-full bg-gradient-primary rounded-r-full transition-all duration-700 cubic-bezier(0.4, 0, 0.2, 1)" id="progress-bar" style="width: 33.33%"></div>
        </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="max-w-xl mx-auto bg-error/10 border border-error/20 text-error p-4 rounded-xl mb-6 text-sm flex gap-3 items-center animate-in fade-in slide-in-from-top-4 duration-300">
            <span class="material-symbols-outlined">error</span>
            <%= error %>
        </div>
    <% } %>

    <form id="botForm" action="<%= formAction %><%= formAction.includes('?') ? '&' : '?' %>_csrf=<%= csrfToken %>" method="post" enctype="multipart/form-data" class="max-w-xl mx-auto">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <!-- Step 1: Persona Identity -->
        <div class="wizard-step space-y-stack-md animate-in fade-in slide-in-from-bottom-4 duration-500" data-step="1">
            <div class="space-y-base">
                <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface"><%= t('form.whoIsAgent') %></h2>
                <p class="font-body-md text-body-md text-on-surface-variant"><%= t('form.step1Desc') %></p>
            </div>

            <!-- Templates -->
                <% if (!isEdit) { %>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                        <button type="button" onclick="applyTemplate('professional')" class="glass-panel rounded-3xl p-5 flex flex-col items-start text-left gap-3 hover:bg-primary/10 hover:border-primary/30 transition-all hover:shadow-xl active:scale-[0.98] group relative">
                            <span class="text-4xl p-3 bg-surface-container-highest/50 rounded-2xl shadow-inner group-hover:scale-110 transition-transform">👔</span>
                            <div>
                                <span class="font-headline-md text-headline-md text-on-surface font-bold group-hover:text-primary transition-colors"><%= t('form.templateProfessional') %></span>
                                <p class="text-xs text-on-surface-variant mt-1 leading-relaxed"><%= t('form.templateProfessionalDesc') %></p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-2">
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/5 border border-outline/10 text-on-surface-variant font-bold"><%= t('form.tagProfessional') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagWeb') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagTime') %></span>
                            </div>
                        </button>
                        
                        <button type="button" onclick="applyTemplate('creative')" class="glass-panel rounded-3xl p-5 flex flex-col items-start text-left gap-3 hover:bg-primary/10 hover:border-primary/30 transition-all hover:shadow-xl active:scale-[0.98] group relative">
                            <span class="text-4xl p-3 bg-surface-container-highest/50 rounded-2xl shadow-inner group-hover:scale-110 transition-transform">🎨</span>
                            <div>
                                <span class="font-headline-md text-headline-md text-on-surface font-bold group-hover:text-primary transition-colors"><%= t('form.templateCreative') %></span>
                                <p class="text-xs text-on-surface-variant mt-1 leading-relaxed"><%= t('form.templateCreativeDesc') %></p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-2">
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/5 border border-outline/10 text-on-surface-variant font-bold"><%= t('form.tagCreative') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagMemory') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagWeb') %></span>
                            </div>
                        </button>
                        
                        <button type="button" onclick="applyTemplate('researcher')" class="glass-panel rounded-3xl p-5 flex flex-col items-start text-left gap-3 hover:bg-primary/10 hover:border-primary/30 transition-all hover:shadow-xl active:scale-[0.98] group relative">
                            <span class="text-4xl p-3 bg-surface-container-highest/50 rounded-2xl shadow-inner group-hover:scale-110 transition-transform">🔍</span>
                            <div>
                                <span class="font-headline-md text-headline-md text-on-surface font-bold group-hover:text-primary transition-colors"><%= t('form.templateResearcher') %></span>
                                <p class="text-xs text-on-surface-variant mt-1 leading-relaxed"><%= t('form.templateResearcherDesc') %></p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-2">
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/5 border border-outline/10 text-on-surface-variant font-bold"><%= t('form.tagAnalytical') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagWikipedia') %></span>
                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary/10 text-primary font-bold"><%= t('form.tagWeb') %></span>
                            </div>
                        </button>
                    </div>
                <% } %>

            <div class="glass-panel rounded-3xl p-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <%- include("partials/input", { 
                        name: "personaName", 
                        type: "text", 
                        label: t('form.personaNameLabel'), 
                        placeholder: bot ? '' : t('form.personaNamePlaceholder'), 
                        value: bot ? bot.persona_name : '', 
                        required: true, 
                        oninput: "updateMockup()" 
                    }) %>
                    <%- include("partials/input", { 
                        name: "personaProfession", 
                        type: "text", 
                        label: t('form.professionLabel'), 
                        placeholder: bot ? '' : t('form.professionPlaceholder'), 
                        value: bot ? bot.persona_profession : '', 
                        required: true, 
                        oninput: "updateMockup()" 
                    }) %>
                </div>

                <%- include("partials/input", { 
                    name: "personaDescription", 
                    label: t('form.bioLabel'), 
                    placeholder: bot ? '' : t('form.bioPlaceholder'), 
                    value: bot ? bot.persona_description : '', 
                    isTextarea: true, 
                    rows: 3 
                }) %>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="label-enhanced" for="photo-url-field"><%= t('form.photoUrlLabel') %></label>
                        <div class="relative h-[58px]">
                            <% if (bot && bot.photo_url && bot.photo_url.startsWith('/uploads/')) { %>
                                <div id="photo-indicator" class="input-enhanced flex items-center gap-2 h-full w-full">
                                    <span class="material-symbols-outlined text-sm">image</span>
                                    <span class="flex-1 text-on-surface-variant truncate"><%= t('form.photoUploaded') %></span>
                                    <button type="button" onclick="this.closest('#photo-indicator').style.display='none';const field = document.getElementById('photo-url-field');field.style.display='block';field.focus();" class="text-primary text-xs font-bold hover:underline shrink-0 focus:outline-none bg-transparent border-none p-0 cursor-pointer"><%= t('form.photoChangeUrl') %></button>
                                </div>
                                <input type="url" id="photo-url-field" name="photoUrl" class="input-enhanced w-full h-full" style="display: none;" placeholder="<%= t('form.photoUrlPlaceholder') %>" oninput="updateMockup()" />
                            <% } else { %>
                                <input type="url" id="photo-url-field" name="photoUrl" class="input-enhanced w-full h-full" <% if (bot && bot.photo_url) { %> value="<%= bot.photo_url %>"<% } else { %> placeholder="<%= t('form.photoUrlPlaceholder') %>"<% } %> oninput="updateMockup()" />
                            <% } %>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="label-enhanced" for="photo-file"><%= t('form.uploadPhotoLabel') %></label>
                        <div class="relative group h-[58px]">
                            <input type="file" id="photo-file" name="photo" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 m-0 p-0 block border-0" title="" accept="image/*" onchange="previewUploadedPhoto(this)" />
                            <div class="input-enhanced w-full h-full flex items-center justify-center gap-2 border-dashed text-on-surface-variant text-sm font-bold group-hover:border-primary group-hover:text-primary group-hover:bg-primary/5 group-hover:shadow-md transition-all shadow-inner">
                                <span class="material-symbols-outlined text-[20px]">upload</span>
                                <span id="upload-button-text" class="truncate"><%= t('form.chooseImage') %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 2: Skills & Superpowers -->
        <div class="wizard-step space-y-stack-md hidden animate-in fade-in slide-in-from-bottom-4 duration-500" data-step="2">
            <div class="space-y-base">
                <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface flex items-center gap-2">
                    <%= t('form.superpowersLabel') %>
                </h2>
                <p class="font-body-md text-body-md text-on-surface-variant"><%= t('form.superpowersTooltip') %></p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% mcpCatalog.forEach(mcp => {
                   const isChecked = bot && bot.mcp_servers?.includes(mcp.id);
                %>
                <label class="skill-checkbox relative glass-panel rounded-3xl p-6 flex flex-col items-start gap-4 hover:bg-white/5 transition-all cursor-pointer group shadow-lg <%= isChecked ? 'bg-primary/10 border-primary/40' : '' %> focus-within:ring-2 focus-within:ring-primary/70 focus-within:border-primary/40">
                    <input type="checkbox" name="mcpServers" value="<%= mcp.id %>" <%= isChecked ? 'checked' : '' %> class="sr-only" onchange="toggleSkill(this)" />
                    
                    <div class="flex w-full justify-between items-start">
                        <div class="p-3 rounded-2xl bg-surface-container-highest/50 text-3xl shadow-inner">
                            <%= mcp.icon %>
                        </div>
                        <span class="material-symbols-outlined text-primary transition-all duration-300 <%= isChecked ? 'opacity-100 scale-100' : 'opacity-0 scale-50' %>" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </div>
                    
                    <div>
                        <h3 class="font-headline-md text-headline-md text-on-surface group-hover:text-primary transition-colors"><%= t(mcp.nameKey) %></h3>
                        <p class="font-label-sm text-label-sm text-on-surface-variant mt-1 leading-relaxed"><%= t(mcp.descriptionKey) %></p>
                    </div>
                </label>
                <% }) %>
            </div>

            <div class="glass-panel rounded-3xl p-8 space-y-4 shadow-inner">
                <div class="flex items-center gap-2 text-primary">
                    <span class="material-symbols-outlined">link</span>
                    <h3 class="font-label-md text-label-md uppercase tracking-widest font-bold"><%= t('form.websiteContextLabel') %></h3>
                </div>
                <textarea name="ragUrls" class="input-enhanced w-full" rows="3" placeholder="<%= t('form.knowledgePlaceholder') %>"><%= bot ? (bot.rag_urls || []).join("\n") : '' %></textarea>
                <p class="font-label-sm text-label-sm text-on-surface-variant opacity-80 italic"><%= t('form.websiteContextTooltip') %></p>
            </div>
        </div>

        <!-- Step 3: Service Details -->
        <div class="wizard-step space-y-stack-md hidden animate-in fade-in slide-in-from-bottom-4 duration-500" data-step="3">
            <div class="space-y-base">
                <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface"><%= t('form.serviceSettings') %></h2>
                <p class="font-body-md text-body-md text-on-surface-variant"><%= t('form.step3Desc') %></p>
            </div>

            <!-- Personality Tone Preset Selector -->
            <div class="glass-panel rounded-3xl p-8 space-y-6">
                <div class="space-y-3">
                    <label class="label-enhanced"><%= t('form.toneSelectLabel') %></label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="tone-chips">
                        <% 
                           const activeTones = bot && bot.tones ? bot.tones : [];
                        %>
                        <button type="button" aria-pressed="<%= activeTones.includes('friendly') ? 'true' : 'false' %>" onclick="toggleTone('friendly')" data-tone="friendly" class="tone-chip glass-panel rounded-2xl p-4 flex items-center gap-3 border border-outline/10 hover:bg-primary/5 hover:border-primary/30 transition-all cursor-pointer text-left focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <span class="text-3xl shrink-0">😊</span>
                            <div class="flex-1 min-w-0">
                                <div class="font-headline-md text-headline-md text-on-surface font-bold truncate"><%= t('form.toneFriendly') %></div>
                                <p class="text-[11px] text-on-surface-variant truncate"><%= t('form.toneFriendlyDesc') %></p>
                            </div>
                            <span class="material-symbols-outlined text-primary shrink-0 opacity-0 scale-50 transition-all duration-300" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        </button>
                        <button type="button" aria-pressed="<%= activeTones.includes('professional') ? 'true' : 'false' %>" onclick="toggleTone('professional')" data-tone="professional" class="tone-chip glass-panel rounded-2xl p-4 flex items-center gap-3 border border-outline/10 hover:bg-primary/5 hover:border-primary/30 transition-all cursor-pointer text-left focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <span class="text-3xl shrink-0">👔</span>
                            <div class="flex-1 min-w-0">
                                <div class="font-headline-md text-headline-md text-on-surface font-bold truncate"><%= t('form.toneProfessional') %></div>
                                <p class="text-[11px] text-on-surface-variant truncate"><%= t('form.toneProfessionalDesc') %></p>
                            </div>
                            <span class="material-symbols-outlined text-primary shrink-0 opacity-0 scale-50 transition-all duration-300" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        </button>
                        <button type="button" aria-pressed="<%= activeTones.includes('concise') ? 'true' : 'false' %>" onclick="toggleTone('concise')" data-tone="concise" class="tone-chip glass-panel rounded-2xl p-4 flex items-center gap-3 border border-outline/10 hover:bg-primary/5 hover:border-primary/30 transition-all cursor-pointer text-left focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <span class="text-3xl shrink-0">⚡</span>
                            <div class="flex-1 min-w-0">
                                <div class="font-headline-md text-headline-md text-on-surface font-bold truncate"><%= t('form.toneConcise') %></div>
                                <p class="text-[11px] text-on-surface-variant truncate"><%= t('form.toneConciseDesc') %></p>
                            </div>
                            <span class="material-symbols-outlined text-primary shrink-0 opacity-0 scale-50 transition-all duration-300" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        </button>
                        <button type="button" aria-pressed="<%= activeTones.includes('creative') ? 'true' : 'false' %>" onclick="toggleTone('creative')" data-tone="creative" class="tone-chip glass-panel rounded-2xl p-4 flex items-center gap-3 border border-outline/10 hover:bg-primary/5 hover:border-primary/30 transition-all cursor-pointer text-left focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <span class="text-3xl shrink-0">🎨</span>
                            <div class="flex-1 min-w-0">
                                <div class="font-headline-md text-headline-md text-on-surface font-bold truncate"><%= t('form.toneCreative') %></div>
                                <p class="text-[11px] text-on-surface-variant truncate"><%= t('form.toneCreativeDesc') %></p>
                            </div>
                            <span class="material-symbols-outlined text-primary shrink-0 opacity-0 scale-50 transition-all duration-300" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        </button>
                    </div>
                    <input type="hidden" name="tones" id="tones-input" value="<%= bot && bot.tones ? bot.tones.join(',') : '' %>" />
                </div>
            </div>

            <!-- Collapsible Advanced Settings (Optional) -->
            <details class="group border border-outline/10 rounded-3xl bg-surface-container-lowest/30 transition-all overflow-hidden duration-300">
                <summary class="flex justify-between items-center p-6 cursor-pointer select-none font-bold text-on-surface hover:text-primary list-none [&::-webkit-details-marker]:hidden">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                        <h3 class="font-label-md text-label-md uppercase tracking-widest font-bold"><%= t('form.advancedServiceSettings') %></h3>
                    </div>
                </summary>
                <div class="px-8 pb-8 space-y-6 border-t border-outline/5 pt-6">
                    <%- include("partials/input", { 
                        name: "serviceName", 
                        type: "text", 
                        label: t('form.serviceNameLabel'), 
                        placeholder: bot ? '' : t('form.serviceNamePlaceholder'), 
                        value: bot ? bot.service_name : '', 
                        required: true 
                    }) %>

                    <%- include("partials/input", { 
                        name: "serviceDescription", 
                        type: "text", 
                        label: t('form.serviceTaglineLabel'), 
                        placeholder: bot ? '' : t('form.serviceTaglinePlaceholder'), 
                        value: bot ? bot.service_description : '' 
                    }) %>

                    <div class="space-y-2">
                        <label class="label-enhanced" for="minimumAge"><%= t('form.ageLabel') %></label>
                        <div class="flex items-center gap-6 bg-surface-container-lowest border border-outline rounded-2xl p-4 shadow-inner">
                            <input type="range" id="minimumAge" name="minimumAge" min="1" max="100" value="<%= bot ? (bot.minimum_age || 1) : 1 %>" class="flex-1 accent-primary h-1.5 bg-surface-container rounded-full appearance-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/50" oninput="document.getElementById('age-val').innerText = this.value" />
                            <span class="w-14 text-center font-bold text-primary bg-primary/10 py-2 rounded-xl text-lg border border-primary/20" id="age-val"><%= bot ? (bot.minimum_age || 1) : 1 %></span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="label-enhanced" for="language"><%= t('form.languageLabel') %></label>
                        <div class="relative">
                            <select id="language" name="language" class="input-enhanced w-full h-[58px] px-4 pr-10 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/50 appearance-none bg-no-repeat bg-[right_1.25rem_center] bg-[length:1.25em_1.25em]" style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E');">
                                <option value="auto" <%= (bot && bot.language === 'auto') || !bot ? 'selected' : '' %>><%= t('form.languageAuto') %></option>
                                <option value="es" <%= bot && bot.language === 'es' ? 'selected' : '' %>><%= t('form.languageEs') %></option>
                                <option value="en" <%= bot && bot.language === 'en' ? 'selected' : '' %>><%= t('form.languageEn') %></option>
                            </select>
                        </div>
                    </div>
                </div>
            </details>

            <!-- Advanced Prompts (Optional) -->
            <details class="group border border-outline/10 rounded-3xl bg-surface-container-lowest/30 transition-all overflow-hidden duration-300">
                <summary class="flex justify-between items-center p-6 cursor-pointer select-none font-bold text-on-surface hover:text-primary list-none [&::-webkit-details-marker]:hidden">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                        <h3 class="font-label-md text-label-md uppercase tracking-widest font-bold"><%= t('form.advancedDeveloperPrompts') %></h3>
                    </div>
                </summary>
                <div class="px-8 pb-8 space-y-4 border-t border-outline/5 pt-6">
                    <textarea id="prompt" name="prompt" class="input-enhanced w-full" rows="6" placeholder="<%= t('form.aiPersonalityPlaceholderSimplified') %>"><%= bot ? bot.prompt : '' %></textarea>
                    <p class="font-label-sm text-label-sm text-on-surface-variant opacity-80 italic"><%= t('form.aiPersonalityHint') %></p>
                </div>
            </details>
        </div>

        <!-- Hidden Form Controls -->
        <div class="flex gap-4 mt-12 pb-32">
            <button type="button" id="backBtn" class="btn-outline btn-base flex-1 py-4 font-bold hidden active:scale-95">
                <%= t('form.backButton') %>
            </button>
            <button type="button" id="nextBtn" class="btn-primary btn-base flex-[2] py-4 font-bold shadow-xl active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                <%= t('form.continueButton') %>
                <span class="material-symbols-outlined">arrow_forward</span>
            </button>
            <button type="submit" id="submitBtn" class="btn-primary btn-base flex-[2] py-4 font-bold shadow-xl hidden active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                <%= submitLabel %>
            </button>
        </div>
    </form>
</div>

<!-- Fixed Bottom Action Area & Preview Snippet -->
<div aria-hidden="true" class="fixed bottom-0 left-0 right-0 p-margin-mobile bg-surface backdrop-blur-xl z-50 rounded-t-[32px] inner-glow pb-8 animate-in slide-in-from-bottom-full duration-700 delay-300">
    <div class="max-w-xl mx-auto">
        <!-- Live Preview Snippet -->
        <div class="flex items-center gap-5 p-5 glass-panel rounded-3xl shadow-2xl min-h-28">
            <div class="w-20 h-20 rounded-2xl overflow-hidden bg-surface-container flex-shrink-0 border border-outline/10 shadow-inner aspect-square">
                <img id="preview-avatar" alt="Agent Avatar" class="w-full h-full object-cover" src="<%= bot?.photo_url || 'data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g%22%20x1%3D%220%25%22%20y1%3D%220%25%22%20x2%3D%22100%25%22%20y2%3D%22100%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237c3aed%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23c084fc%22%2F%3E%3C%2FlinearGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%22100%22%20height%3D%22100%22%20rx%3D%2220%22%20fill%3D%22url(%23g)%22%2F%3E%3Ccircle%20cx%3D%2235%22%20cy%3D%2238%22%20r%3D%225%22%20fill%3D%22%23fff%22%20opacity%3D%220.9%22%2F%3E%3Ccircle%20cx%3D%2265%22%20cy%3D%2238%22%20r%3D%225%22%20fill%3D%22%23fff%22%20opacity%3D%220.9%22%2F%3E%3Cpath%20d%3D%22M35%2062%20Q50%2075%2065%2062%22%20stroke%3D%22%23fff%22%20stroke-width%3D%223%22%20fill%3D%22none%22%20stroke-linecap%3D%22round%22%20opacity%3D%220.9%22%2F%3E%3C%2Fsvg%3E' %>" />
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
                <div class="flex items-center gap-2">
                    <h4 class="font-headline-md text-headline-md text-on-surface truncate" id="preview-name"><%= bot?.persona_name || 'Assistant' %></h4>
                    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                </div>
                <p class="font-label-sm text-label-sm text-on-surface-variant truncate opacity-80" id="preview-role"><%= bot?.persona_profession || 'Digital Assistant' %></p>
                <div class="flex gap-2 mt-1 overflow-x-auto no-scrollbar scroll-smooth pb-0.5" id="preview-skills">
                    <!-- Skills will be injected here -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Define saveWizardState globally before IIFE runs
    window._wizardStep = 1;
    window.saveWizardState = () => {
        const form = document.getElementById('botForm');
        if (!form) return true;
        try {
            const data = new FormData(form);
            const state = { step: window._wizardStep || 1, values: {}, mcps: [], botId: '<%= isEdit ? bot.id : "new" %>' };
            for (const [key, value] of data.entries()) {
                if (key !== 'photo' && key !== '_csrf') state.values[key] = value;
            }
            document.querySelectorAll('input[name="mcpServers"]:checked').forEach(cb => state.mcps.push(cb.value));
            sessionStorage.setItem('wizardState', JSON.stringify(state));
        } catch (e) {}
        return true;
    };

    (() => {
        const steps = Array.from(document.querySelectorAll(".wizard-step"));
        const backBtn = document.getElementById("backBtn");
        const nextBtn = document.getElementById("nextBtn");
        const submitBtn = document.getElementById("submitBtn");
        const progressBar = document.getElementById("progress-bar");
        const stepCount = document.getElementById("step-count");
        const stepTitleEl = document.getElementById("step-title");
        const defaultAvatar = 'data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g%22%20x1%3D%220%25%22%20y1%3D%220%25%22%20x2%3D%22100%25%22%20y2%3D%22100%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237c3aed%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23c084fc%22%2F%3E%3C%2FlinearGradient%3E%3C%2Fdefs%3E%3Ccircle%20cx%3D%2250%22%20cy%3D%2250%22%20r%3D%2250%22%20fill%3D%22url(%23g)%22%2F%3E%3Ccircle%20cx%3D%2235%22%20cy%3D%2238%22%20r%3D%225%22%20fill%3D%22%23fff%22%20opacity%3D%220.9%22%2F%3E%3Ccircle%20cx%3D%2265%22%20cy%3D%2238%22%20r%3D%225%22%20fill%3D%22%23fff%22%20opacity%3D%220.9%22%2F%3E%3Cpath%20d%3D%22M35%2062%20Q50%2075%2065%2062%22%20stroke%3D%22%23fff%22%20stroke-width%3D%223%22%20fill%3D%22none%22%20stroke-linecap%3D%22round%22%20opacity%3D%220.9%22%2F%3E%3C%2Fsvg%3E';
        const currentBotId = '<%= isEdit ? bot.id : "new" %>';
        const avatarEl = document.getElementById('preview-avatar');
        const initialAvatarSrc = avatarEl.src;
        
        let currentStep = 1;
        const totalSteps = 3;
        
        const titles = ["<%- t('form.step1Title') %>", "<%- t('form.step2Title') %>", "<%- t('form.step3Title') %>"];

        const sync = () => {
            steps.forEach((el) => {
                const stepNum = Number(el.dataset.step);
                el.classList.toggle("hidden", stepNum !== currentStep);
                if (stepNum === currentStep) {
                    el.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-4');
                    // Shift screen reader focus to the start of the new step
                    const heading = el.querySelector('h2');
                    if (heading) {
                        heading.setAttribute('tabindex', '-1');
                        heading.classList.add('focus:outline-none');
                        heading.focus();
                    }
                }
            });
            
            backBtn.classList.toggle("hidden", currentStep === 1);
            nextBtn.classList.toggle("hidden", currentStep === totalSteps);
            submitBtn.classList.toggle("hidden", currentStep !== totalSteps);
            
            progressBar.style.width = `${(currentStep / totalSteps) * 100}%`;
            stepCount.innerText = "<%= t('form.stepOf') %>".replace("{0}", currentStep).replace("{1}", totalSteps);
            stepTitleEl.innerText = titles[currentStep - 1];
            
            // Sync with global variable for saveWizardState
            window._wizardStep = currentStep;
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

        backBtn?.addEventListener("click", () => {
            currentStep = Math.max(1, currentStep - 1);
            sync();
        });
        
        nextBtn?.addEventListener("click", () => {
            const currentEl = steps.find(s => Number(s.dataset.step) === currentStep);
            const inputs = currentEl.querySelectorAll('input[required]');
            let valid = true;
            inputs.forEach(i => { if(!i.value) { i.classList.add('border-error'); valid = false; } else { i.classList.remove('border-error'); } });
            
            if (valid) {
                currentStep = Math.min(totalSteps, currentStep + 1);
                sync();
            } else {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });

        // Skill Toggle Logic
        window.toggleSkill = (checkbox) => {
            const card = checkbox.parentElement;
            const isChecked = checkbox.checked;
            card.classList.toggle('bg-primary/10', isChecked);
            card.classList.toggle('border-primary/40', isChecked);
            const icon = card.querySelector('.material-symbols-outlined');
            if (icon) {
                icon.classList.toggle('opacity-100', isChecked);
                icon.classList.toggle('scale-100', isChecked);
                icon.classList.toggle('opacity-0', !isChecked);
                icon.classList.toggle('scale-50', !isChecked);
            }
            updatePreviewSkills();
        };

        const updatePreviewSkills = () => {
            const container = document.getElementById('preview-skills');
            container.innerHTML = '';
            const checked = document.querySelectorAll('input[name="mcpServers"]:checked');
            if (checked.length === 0) {
                container.innerHTML = '<span class="font-label-sm text-label-sm text-on-surface-variant italic opacity-75"><%= t('form.noToolsSelected') %></span>';
                return;
            }
            checked.forEach(cb => {
                const label = cb.parentElement.querySelector('.font-headline-md').innerText;
                const iconHtml = cb.parentElement.querySelector('.bg-surface-container-highest\\/50').innerHTML;
                
                const skillTag = document.createElement('span');
                skillTag.className = "inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 whitespace-nowrap animate-in zoom-in-50 duration-300";
                skillTag.innerHTML = `<span class="text-[12px] flex items-center">${iconHtml}</span><span class="font-label-sm text-label-sm text-primary font-bold">${label}</span>`;
                container.appendChild(skillTag);
            });
        };

        window.updateMockup = () => {
            const name = document.getElementById('personaName').value || 'Assistant';
            const role = document.getElementById('personaProfession').value || 'Digital Assistant';
            const photoUrlInput = document.getElementById('photo-url-field');
            const photoUrl = photoUrlInput ? photoUrlInput.value : '';
            const fileInput = document.querySelector('input[name="photo"]');
            
            document.getElementById('preview-name').innerText = name;
            document.getElementById('preview-role').innerText = role;
            
            if (photoUrl) {
                document.getElementById('preview-avatar').src = photoUrl;
            } else if (!fileInput?.files?.length) {
                document.getElementById('preview-avatar').src = initialAvatarSrc;
            }
        };

        window.previewUploadedPhoto = (input) => {
            const file = input.files?.[0];
            const textEl = document.getElementById('upload-button-text');
            const defaultText = "<%= t('form.chooseImage') %>";
            
            if (input.dataset.cropping === 'true') {
                return;
            }
            
            if (!file) {
                if (textEl) textEl.innerText = defaultText;
                return;
            }
            if (!file.type.startsWith('image/')) {
                alert('<%= t('form.invalidFileType') %>');
                input.value = '';
                if (textEl) textEl.innerText = defaultText;
                return;
            }
            if (file.size > 5 * 1024 * 1024) {
                alert('<%= t('form.invalidFileSize') %>');
                input.value = '';
                if (textEl) textEl.innerText = defaultText;
                return;
            }

            const reader = new FileReader();
            reader.onload = (e) => {
                const img = new Image();
                img.onload = () => {
                    // Create a canvas to crop the image to 1:1 square
                    const canvas = document.createElement('canvas');
                    const size = Math.min(img.width, img.height);
                    
                    // We target 800x800px maximum to optimize resolution and size
                    const targetSize = Math.min(size, 800);
                    canvas.width = targetSize;
                    canvas.height = targetSize;
                    
                    const ctx = canvas.getContext('2d');
                    if (!ctx) {
                        document.getElementById('preview-avatar').src = e.target.result;
                        return;
                    }
                    
                    // Center the cropping box (square)
                    const sx = (img.width - size) / 2;
                    const sy = (img.height - size) / 2;
                    
                    ctx.drawImage(img, sx, sy, size, size, 0, 0, targetSize, targetSize);
                    
                    // Convert to jpeg blob
                    canvas.toBlob((blob) => {
                        if (!blob) {
                            document.getElementById('preview-avatar').src = e.target.result;
                            return;
                        }
                        
                        try {
                            // Create a new File object from the blob
                            const croppedFile = new File([blob], file.name.replace(/\.[^/.]+$/, "") + "_1x1.jpg", { type: 'image/jpeg' });
                            
                            // Use DataTransfer to replace the input file
                            input.dataset.cropping = 'true';
                            const dataTransfer = new DataTransfer();
                            dataTransfer.items.add(croppedFile);
                            input.files = dataTransfer.files;
                            input.removeAttribute('data-cropping');
                            
                            // Update label and preview
                            if (textEl) {
                                const maxLen = 20;
                                const filename = croppedFile.name;
                                textEl.innerText = filename.length > maxLen ? filename.substring(0, maxLen) + '...' : filename;
                            }
                            
                            // Set preview avatar source to the 1:1 image
                            document.getElementById('preview-avatar').src = URL.createObjectURL(blob);
                        } catch (err) {
                            console.error("Error cropping image:", err);
                            // Fallback to original image if File/DataTransfer fails
                            document.getElementById('preview-avatar').src = e.target.result;
                        }
                    }, 'image/jpeg', 0.9);
                };
                img.onerror = () => {
                    alert('<%= t('form.invalidFileType') %>');
                    input.value = '';
                    if (textEl) textEl.innerText = defaultText;
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        };

        window.toggleTone = (tone) => {
            const input = document.getElementById('tones-input');
            let tones = input.value ? input.value.split(',').filter(Boolean) : [];
            
            const index = tones.indexOf(tone);
            if (index > -1) {
                tones.splice(index, 1);
            } else {
                tones.push(tone);
            }
            
            input.value = tones.join(',');
            
            const chip = document.querySelector(`.tone-chip[data-tone="${tone}"]`);
            if (chip) {
                const isSelected = tones.includes(tone);
                chip.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
                chip.classList.toggle('bg-primary/10', isSelected);
                chip.classList.toggle('border-primary/40', isSelected);
                
                const checkIcon = chip.querySelector('.material-symbols-outlined');
                if (checkIcon) {
                    checkIcon.classList.toggle('opacity-100', isSelected);
                    checkIcon.classList.toggle('scale-100', isSelected);
                    checkIcon.classList.toggle('opacity-0', !isSelected);
                    checkIcon.classList.toggle('scale-50', !isSelected);
                }
            }
        };

        window.selectTones = (toneList) => {
            const input = document.getElementById('tones-input');
            input.value = toneList.join(',');
            
            document.querySelectorAll('.tone-chip').forEach(chip => {
                const tone = chip.getAttribute('data-tone');
                const isSelected = toneList.includes(tone);
                chip.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
                chip.classList.toggle('bg-primary/10', isSelected);
                chip.classList.toggle('border-primary/40', isSelected);
                
                const checkIcon = chip.querySelector('.material-symbols-outlined');
                if (checkIcon) {
                    checkIcon.classList.toggle('opacity-100', isSelected);
                    checkIcon.classList.toggle('scale-100', isSelected);
                    checkIcon.classList.toggle('opacity-0', !isSelected);
                    checkIcon.classList.toggle('scale-50', !isSelected);
                }
            });
        };

        // Smart dynamic autofill listeners
        const pName = document.getElementById('personaName');
        const pProfession = document.getElementById('personaProfession');
        const sName = document.getElementById('serviceName');
        const sDescription = document.getElementById('serviceDescription');

        let isServiceNameDirty = sName && sName.value !== '';
        let isServiceDescriptionDirty = sDescription && sDescription.value !== '';

        sName?.addEventListener('input', () => { isServiceNameDirty = true; });
        sDescription?.addEventListener('input', () => { isServiceDescriptionDirty = true; });

        pName?.addEventListener('input', () => {
            if (!isServiceNameDirty && sName) {
                sName.value = pName.value ? `${pName.value} <%= t('form.assistantSuffix') %>` : '';
            }
        });

        pProfession?.addEventListener('input', () => {
            if (!isServiceDescriptionDirty && sDescription) {
                sDescription.value = pProfession.value || '';
            }
        });

        window.applyTemplate = (type) => {
            const templates = {
                professional: {
                    name: `<%= t('form.presetProfessionalName') %>`,
                    role: `<%= t('form.presetProfessionalRole') %>`,
                    bio: `<%= t('form.presetProfessionalBio') %>`,
                    prompt: `<%= t('form.presetProfessionalPrompt') %>`,
                    mcps: ['fetch', 'time'],
                    tones: ['professional']
                },
                creative: {
                    name: `<%= t('form.presetCreativeName') %>`,
                    role: `<%= t('form.presetCreativeRole') %>`,
                    bio: `<%= t('form.presetCreativeBio') %>`,
                    prompt: `<%= t('form.presetCreativePrompt') %>`,
                    mcps: ['fetch', 'memory'],
                    tones: ['creative', 'friendly']
                },
                researcher: {
                    name: `<%= t('form.presetResearcherName') %>`,
                    role: `<%= t('form.presetResearcherRole') %>`,
                    bio: `<%= t('form.presetResearcherBio') %>`,
                    prompt: `<%= t('form.presetResearcherPrompt') %>`,
                    mcps: ['wikipedia', 'fetch', 'memory'],
                    tones: ['professional', 'concise']
                }
            };
            
            const t = templates[type];
            if (t) {
                document.getElementById('personaName').value = t.name;
                document.getElementById('personaProfession').value = t.role;
                document.querySelector('textarea[name="personaDescription"]').value = t.bio;
                document.getElementById('prompt').value = t.prompt;
                
                // Check recommended MCPs, uncheck others
                document.querySelectorAll('input[name="mcpServers"]').forEach(cb => {
                    const shouldCheck = t.mcps.includes(cb.value);
                    if (cb.checked !== shouldCheck) {
                        cb.checked = shouldCheck;
                        window.toggleSkill(cb);
                    }
                });
                updatePreviewSkills();

                // Check template recommended tones
                if (t.tones) {
                    window.selectTones(t.tones);
                }
                
                [document.getElementById('personaName'), document.getElementById('personaProfession')].forEach(el => {
                    el.classList.add('ring-2', 'ring-primary/50');
                    setTimeout(() => el.classList.remove('ring-2', 'ring-primary/50'), 1000);
                });
                
                updateMockup();
            }
        };


        window.addEventListener('beforeunload', window.saveWizardState);

        const saved = sessionStorage.getItem('wizardState');
        if (saved) {
            try {
                const state = JSON.parse(saved);
                if (!state.botId || state.botId !== currentBotId) { sessionStorage.removeItem('wizardState'); throw 'skip'; }
                for (const [key, value] of Object.entries(state.values)) {
                    if (key === 'mcpServers' || key === '_csrf' || key === 'tones') continue;
                    const el = document.querySelector(`[name="${key}"]`);
                    if (el) { el.value = value; el.dispatchEvent(new Event('input', { bubbles: true })); }
                }
                state.mcps.forEach(v => {
                    const cb = document.querySelector(`input[name="mcpServers"][value="${v}"]`);
                    if (cb) {
                        cb.checked = true;
                        const card = cb.parentElement;
                        card.classList.add('bg-primary/10', 'border-primary/40');
                        const icon = card.querySelector('.material-symbols-outlined');
                        if (icon) {
                            icon.classList.remove('opacity-0', 'scale-50');
                            icon.classList.add('opacity-100', 'scale-100');
                        }
                    }
                });
                if (state.values.tones) {
                    window.selectTones(state.values.tones.split(',').filter(Boolean));
                }
                if (state.step >= 1 && state.step <= totalSteps) {
                    currentStep = state.step;
                    window._wizardStep = currentStep;
                }
                if (<%= isEdit %>) {
                    setTimeout(() => {
                        const t = document.getElementById('restore-toast');
                        if (t) { t.classList.remove('opacity-0', 'pointer-events-none'); setTimeout(() => t.classList.add('opacity-0', 'pointer-events-none'), 3500); }
                    }, 300);
                }
            } catch (e) {}
            sessionStorage.removeItem('wizardState');
        }

        // Restore tones initially if page already contains them
        const initialTones = document.getElementById('tones-input')?.value;
        if (initialTones) {
            window.selectTones(initialTones.split(',').filter(Boolean));
        }

        document.getElementById('botForm')?.addEventListener('submit', () => {
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-60', 'pointer-events-none');
            submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> <%= t('common.loading') %>';
        });

        sync();
        updatePreviewSkills();
        updateMockup();

        // Progressive Stepper Scroll-Driven Interaction (Inward to Outward Curvature Fillets)
        (() => {
            const sentinel = document.getElementById('stepper-sentinel');
            const stepper = document.getElementById('stepper-card');
            if (!stepper || !sentinel) return;
            
            // Cache the resting absolute vertical position relative to the document
            let stepperDocumentTop = 0;
            
            const updateStepperTop = () => {
                // Use sentinel to obtain the true document-relative top position
                // of the stepper regardless of whether it is stuck or not.
                stepperDocumentTop = sentinel.getBoundingClientRect().top + window.scrollY;
            };

            let lastProgress = null;

            const handleScroll = () => {
                const scrollY = window.scrollY;
                const rectTop = stepperDocumentTop - scrollY;
                const triggerStart = 160; // scroll distance in px where progressive collapse starts
                const triggerEnd = 96;   // header bottom sticky point in px (top-24)
                
                let progress = 0;
                if (rectTop <= triggerEnd) {
                    progress = 1;
                } else if (rectTop >= triggerStart) {
                    progress = 0;
                } else {
                    progress = (triggerStart - rectTop) / (triggerStart - triggerEnd);
                }
                
                // Precision clamp to 2 decimal places to avoid microscopic style updates
                progress = Math.round(progress * 100) / 100;
                
                if (progress === lastProgress) return;
                lastProgress = progress;
                
                // Reduce only top two corners' border-radius from 16px to 0px, keeping bottom corners at 16px
                const maxRadius = 16;
                const currentRadius = maxRadius * (1 - progress);
                stepper.style.borderTopLeftRadius = `${currentRadius}px`;
                stepper.style.borderTopRightRadius = `${currentRadius}px`;
                stepper.style.borderBottomLeftRadius = '16px';
                stepper.style.borderBottomRightRadius = '16px';
                
                // Toggle is-stuck class to render and scale the outward fillets
                if (progress >= 1) {
                    stepper.classList.add('is-stuck');
                } else {
                    stepper.classList.remove('is-stuck');
                }
            };
            
            window.addEventListener('resize', () => {
                updateStepperTop();
                handleScroll();
            });

            // Calculate stepper Document Top after window finishes loading (fonts/styles fully resolved)
            window.addEventListener('load', () => {
                updateStepperTop();
                handleScroll();
            });

            window.addEventListener('scroll', handleScroll, { passive: true });
            
            // Initial calculations
            updateStepperTop();
            handleScroll();
        })();
    })();
</script>
