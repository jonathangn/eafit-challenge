<%- include("partials/header") %>

<div class="relative py-20 px-margin-mobile overflow-hidden">
    <div class="max-w-md w-full mx-auto relative z-10 text-center">
        <div class="glass-panel rounded-3xl p-12 space-y-6 shadow-2xl">
            <div class="w-20 h-20 bg-error/10 rounded-full flex items-center justify-center mx-auto text-4xl">
                <%= status === 404 ? '🔍' : '⚠️' %>
            </div>
            <div class="space-y-2">
                <h1 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface"><%= status || 500 %></h1>
                <p class="font-body-md text-body-md text-on-surface-variant"><%= message %></p>
            </div>
            <div class="pt-4">
                <a href="/" class="inline-flex items-center gap-2 btn-primary btn-base px-8 py-3 font-bold shadow-xl hover:scale-105 active:scale-95 transition-transform">
                    <span class="material-symbols-outlined">home</span>
                    <%= t('error.goHome') %>
                </a>
            </div>
        </div>
    </div>
</div>

<%- include("partials/footer") %>

