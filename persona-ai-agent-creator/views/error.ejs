<%- include("partials/header") %>

<% 
  // Determine page subtitle and glow style based on status
  let errorTitle = t('common.toastError'); 
  let glowColor = 'bg-error';
  
  if (status === 404) {
    errorTitle = t('error.pageNotFound');
    glowColor = 'bg-primary';
  } else if (status === 403) {
    errorTitle = t('error.accessDenied');
    glowColor = 'bg-secondary';
  } else if (status === 429) {
    errorTitle = t('error.rateLimitTitle');
    glowColor = 'bg-secondary';
  } else if (status === 410) {
    errorTitle = t('error.botGone');
    glowColor = 'bg-secondary';
  } else if (status === 500) {
    errorTitle = t('error.internalError');
    glowColor = 'bg-error';
  }
%>

<div class="relative min-h-[65vh] grid place-items-center py-20 px-margin-mobile overflow-hidden">
    <!-- Ambient Blur Background -->
    <div class="absolute w-80 h-80 rounded-full filter blur-[120px] opacity-25 pointer-events-none <%= glowColor %> transition-colors duration-500"></div>

    <div class="max-w-xl w-full mx-auto relative z-10 text-center animate-fade-in">
        <div class="glass-panel p-10 md:p-14 space-y-8 shadow-2xl relative overflow-hidden border border-outline/10">
            <!-- Glow Accent on Top Border -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary opacity-60"></div>

            <!-- Handcrafted Stylized SVG Illustrations -->
            <div class="relative h-32 flex items-center justify-center">
                <% if (status === 404) { %>
                    <!-- 404: Scanning Radar / Broken Connection -->
                    <svg class="w-32 h-32 text-primary" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="3" stroke-dasharray="8 6" class="opacity-30" style="animation: spin 30s linear infinite;" />
                        <circle cx="50" cy="50" r="28" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" class="opacity-40" />
                        <line x1="50" y1="50" x2="72" y2="72" stroke="currentColor" stroke-width="4" stroke-linecap="round" class="opacity-75" />
                        <circle cx="50" cy="50" r="8" fill="currentColor" class="text-secondary animate-pulse" />
                        <path d="M25 45H35M65 45H75M45 25V35M45 65V75" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="opacity-30" />
                    </svg>
                <% } else if (status === 403) { %>
                    <!-- 403: Glowing Locked Shield -->
                    <svg class="w-28 h-28 text-secondary" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80" />
                        <rect x="9" y="11" width="6" height="5" rx="1" stroke="currentColor" stroke-width="2" fill="var(--glass-bg)" />
                        <path d="M10.5 11V9.5C10.5 8.67157 11.1716 8 12 8V8C12.8284 8 13.5 8.67157 13.5 9.5V11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                <% } else if (status === 429) { %>
                    <!-- 429: Active Speedometer/Hourglass Time Alert -->
                    <svg class="w-28 h-28 text-secondary animate-pulse" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-40" />
                        <path d="M12 6V12L15.5 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 2V4M12 20V22M4 12H2M20 12H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                <% } else if (status === 410) { %>
                    <!-- 410: Uninstalled / Vanished entity -->
                    <svg class="w-28 h-28 text-secondary" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" class="opacity-50" />
                        <path d="M9.5 9.5 L14.5 14.5 M14.5 9.5 L9.5 14.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        <path d="M8 19 L16 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="opacity-80" />
                    </svg>
                <% } else { %>
                    <!-- 500 / Others: Alert Triangle with pulsating core -->
                    <svg class="w-28 h-28 text-error" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10.29 3.86L1.82 18A2 2 0 0 0 3.53 21h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <circle cx="12" cy="17" r="1.2" fill="currentColor" />
                    </svg>
                <% } %>
            </div>

            <!-- Error Code & Custom Message -->
            <div class="space-y-3">
                <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-surface-container-highest/60 text-outline border border-outline/20">
                    <%= t('error.code') %> <%= status || 500 %>
                </span>
                <h1 class="font-headline-lg font-bold text-gradient-primary tracking-tight">
                    <%= errorTitle %>
                </h1>
                <p class="font-body-md text-on-surface-variant max-w-md mx-auto leading-relaxed">
                    <%= message %>
                </p>
            </div>

            <!-- Premium Navigation CTA -->
            <div class="pt-6 border-t border-outline/10">
                <a href="/" class="inline-flex items-center gap-2 btn-primary btn-base px-8 py-3.5 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-transform hover:shadow-xl hover:shadow-primary/30">
                    <span class="material-symbols-outlined">home</span>
                    <%= t('error.goHome') %>
                </a>
            </div>
        </div>
    </div>
</div>

<%- include("partials/footer") %>
