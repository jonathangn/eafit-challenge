<%- include("partials/header") %>

<div class="relative py-20 px-margin-mobile">
    <!-- Abstract gradient blob -->
    <div class="absolute top-1/4 -left-1/4 w-[500px] h-[500px] rounded-full bg-primary/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-md w-full mx-auto relative z-10">
        <!-- Header -->
        <div class="text-center mb-10">
            <h2 class="font-headline-lg-mobile text-headline-lg-mobile mb-2 text-gradient-primary">
                <%= t('auth.resetPasswordTitle') %>
            </h2>
            <p class="font-body-md text-body-md text-on-surface-variant">
                <%= t('auth.resetPasswordSubtitle') %>
            </p>
        </div>

        <!-- Reset Card -->
        <div class="glass-panel p-8 shadow-2xl">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-error/10 border border-error/20 text-error p-4 rounded-xl mb-6 text-sm flex gap-3 items-center">
                    <span class="material-symbols-outlined">error</span>
                    <%= error %>
                </div>
            <% } %>

            <form action="/reset-password/<%= token %>" method="post" class="space-y-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                
                <div class="space-y-2">
                    <label class="label-enhanced" for="reset-password-input"><%= t('auth.passwordLabel') %></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface">lock</span>
                        <input
                            id="reset-password-input"
                            type="password"
                            name="password"
                            class="input-enhanced w-full h-[58px] pl-10 pr-12"
                            required
                            minlength="8"
                            autocomplete="new-password"
                            placeholder="<%= t('auth.passwordPlaceholder') %>"
                        />
                        <button type="button" onclick="const i=this.previousElementSibling;const t=i.type==='password'?'text':'password';i.type=t;this.querySelector('.material-symbols-outlined').textContent=t==='password'?'visibility':'visibility_off'" class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface hover:text-primary transition-colors p-1" aria-label="Toggle password visibility">
                            <span class="material-symbols-outlined text-[20px]" aria-hidden="true">visibility</span>
                        </button>
                    </div>
                    <p class="font-label-sm text-label-sm text-on-surface-variant mt-2"><%= t('auth.passwordHint') %></p>
                </div>

                <button type="submit" id="reset-submit" class="btn-primary btn-base w-full py-3 font-bold shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
                    <span id="reset-submit-text"><%= t('auth.resetPasswordSubmit') %></span>
                    <span id="reset-submit-icon" class="material-symbols-outlined">save</span>
                </button>
                <script>
                    document.querySelector('form[action^="/reset-password/"]')?.addEventListener('submit', function() {
                        const b = document.getElementById('reset-submit');
                        b.disabled = true;
                        b.classList.add('opacity-50', 'pointer-events-none');
                        document.getElementById('reset-submit-text').textContent = '<%= t('common.loading') %>';
                        document.getElementById('reset-submit-icon').textContent = 'sync';
                        document.getElementById('reset-submit-icon').classList.add('animate-spin');
                    });
                </script>
            </form>
        </div>
    </div>
</div>

<%- include("partials/footer") %>
