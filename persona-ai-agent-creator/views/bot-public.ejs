<%- include("partials/header") %>

<!-- Structured Schema.org Metadata for Search Engine Rich Cards -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "<%= bot.persona_name || bot.service_name %>",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "All",
  "description": "<%= bot.persona_description || bot.service_description %>",
  "softwareVersion": "1.0.0",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Persona Studio"
  }
}
</script>

<div class="relative min-h-[85vh] py-12 px-margin-mobile overflow-hidden flex items-center justify-center">
  <!-- Dynamic Glowing Background Sphere -->
  <div class="absolute w-[450px] h-[450px] rounded-full filter blur-[150px] opacity-20 pointer-events-none bg-primary top-10 left-10"></div>
  <div class="absolute w-[350px] h-[350px] rounded-full filter blur-[120px] opacity-15 pointer-events-none bg-secondary bottom-10 right-10"></div>

  <div class="max-w-4xl w-full mx-auto relative z-10 animate-fade-in">
    <!-- Main Glassmorphism Panel -->
    <div class="glass-panel p-8 md:p-12 shadow-2xl relative overflow-hidden border border-outline/10 rounded-3xl">
      <!-- Glow Accent Line -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary opacity-70"></div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
        <!-- Column Left: Identity & Visual Profile (5 cols) -->
        <div class="lg:col-span-5 flex flex-col items-center text-center space-y-6">
          <div class="relative">
            <!-- Glowing Ring Frame -->
            <div class="absolute -inset-1.5 bg-gradient-to-r from-primary to-secondary rounded-full blur opacity-75 animate-pulse"></div>
            <!-- Avatar Container -->
            <div class="relative w-44 h-44 rounded-full overflow-hidden border-2 border-background bg-surface-container flex items-center justify-center">
              <% if (bot.photo_url) { %>
                <img src="<%= bot.photo_url %>" alt="<%= bot.persona_name %>" class="w-full h-full object-cover" />
              <% } else { %>
                <span class="material-symbols-outlined text-8xl text-gradient-primary">smart_toy</span>
              <% } %>
            </div>
          </div>

          <div class="space-y-2">
            <!-- Status Badge -->
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-success-container/30 text-success border border-success/30">
              <span class="w-2 h-2 rounded-full bg-success animate-ping"></span>
              <%= currentLang === 'es' ? 'EN VIVO' : 'LIVE' %>
            </span>

            <h1 class="font-headline-lg font-bold text-gradient-primary tracking-tight">
              <%= bot.persona_name || bot.service_name %>
            </h1>
            <p class="font-title-md text-secondary font-medium tracking-wide">
              <%= bot.persona_profession %>
            </p>
          </div>

          <!-- Stylized High-tech QR Code for Hologram Connection -->
          <div class="p-4 bg-white/5 border border-outline/10 rounded-2xl flex flex-col items-center space-y-3 w-full max-w-[220px]">
            <svg class="w-36 h-36 text-white" viewBox="0 0 100 100" fill="currentColor">
              <!-- Handcrafted Beautiful High-Tech Cyber QR Code Mock -->
              <rect x="5" y="5" width="25" height="25" fill="none" stroke="currentColor" stroke-width="4" />
              <rect x="10" y="10" width="15" height="15" />
              <rect x="70" y="5" width="25" height="25" fill="none" stroke="currentColor" stroke-width="4" />
              <rect x="75" y="10" width="15" height="15" />
              <rect x="5" y="70" width="25" height="25" fill="none" stroke="currentColor" stroke-width="4" />
              <rect x="10" y="75" width="15" height="15" />
              
              <!-- Core grid paths -->
              <path d="M 35,10 H 65 M 35,20 H 50 V 30 H 65 M 35,45 H 45 V 55 H 65 V 65 H 35 Z" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="2 3" />
              <path d="M 10,35 V 65 M 20,35 V 50 H 30 M 75,35 V 65 M 85,35 V 55 H 95" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="3 2" />
              <path d="M 35,75 H 65 V 85 H 95 M 35,85 H 70 V 95 H 95" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="2 2" />
            </svg>
            <span class="text-[10px] font-bold tracking-wider text-outline uppercase">
              <%= currentLang === 'es' ? 'Escanea para Chatear' : 'Scan to Connect' %>
            </span>
          </div>
        </div>

        <!-- Column Right: Details, Bio & Superpowers (7 cols) -->
        <div class="lg:col-span-7 flex flex-col justify-between space-y-8">
          <div class="space-y-6">
            <!-- Bio Section -->
            <div class="space-y-2">
              <h2 class="font-title-md font-bold text-on-surface/90">
                <%= currentLang === 'es' ? 'Acerca del Agente' : 'About the Agent' %>
              </h2>
              <p class="font-body-md text-on-surface-variant leading-relaxed">
                <%= bot.persona_description || bot.service_description %>
              </p>
            </div>

            <!-- Active Superpowers (MCP Servers) -->
            <% if (bot.mcp_servers && bot.mcp_servers.length > 0) { %>
              <div class="space-y-3">
                <h3 class="font-title-sm font-bold text-on-surface/90 flex items-center gap-2">
                  <span class="material-symbols-outlined text-secondary">bolt</span>
                  <%= currentLang === 'es' ? 'Superpoderes Habilitados' : 'Enabled Superpowers' %>
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <% bot.mcp_servers.forEach(mcp => { %>
                    <div class="p-3 bg-surface-container-low border border-outline/10 rounded-xl flex items-start gap-3">
                      <span class="material-symbols-outlined text-primary mt-0.5">
                        <%= mcp === 'memory' ? 'database' : mcp === 'weather' ? 'cloud' : mcp === 'wikipedia' ? 'menu_book' : mcp === 'time' ? 'schedule' : 'public' %>
                      </span>
                      <div>
                        <h4 class="text-sm font-bold text-on-surface">
                          <%= t(`mcp.${mcp}.name`) %>
                        </h4>
                        <p class="text-xs text-on-surface-variant leading-normal mt-0.5">
                          <%= t(`mcp.${mcp}.description`) %>
                        </p>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <!-- Connection Specs -->
            <div class="p-4 bg-surface-container border border-outline/10 rounded-2xl space-y-2.5">
              <div class="flex justify-between items-center text-xs">
                <span class="text-on-surface-variant font-medium"><%= currentLang === 'es' ? 'Servicio Relacionado' : 'Related Service' %></span>
                <span class="text-on-surface font-bold"><%= bot.service_name %></span>
              </div>
              <div class="flex justify-between items-center text-xs">
                <span class="text-on-surface-variant font-medium"><%= currentLang === 'es' ? 'Edad Recomendada' : 'Age Restriction' %></span>
                <span class="text-on-surface font-bold"><%= bot.minimum_age || 1 %>+</span>
              </div>
              <% if (bot.language && bot.language !== 'auto') { %>
                <div class="flex justify-between items-center text-xs">
                  <span class="text-on-surface-variant font-medium"><%= currentLang === 'es' ? 'Idioma del Bot' : 'Bot Language' %></span>
                  <span class="text-on-surface font-bold"><%= bot.language === 'es' ? 'Español' : 'English' %></span>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Bottom CTA Buttons -->
          <div class="space-y-4 pt-6 border-t border-outline/10">
            <a href="hologram://connect?endpoint=<%= encodeURIComponent(bot.public_url || '') %>" class="w-full flex items-center justify-center gap-3 btn-primary btn-base py-4 rounded-xl font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-transform hover:shadow-xl hover:shadow-primary/30 text-on-primary">
              <span class="material-symbols-outlined">forum</span>
              <%= currentLang === 'es' ? 'Chatear con el Agente' : 'Chat with the Agent' %>
            </a>
            
            <button onclick="copyPublicUrl()" class="w-full flex items-center justify-center gap-2 px-4 py-3 border border-outline/20 hover:bg-surface-container-highest/40 rounded-xl transition-colors text-sm font-bold text-on-surface">
              <span class="material-symbols-outlined text-base">content_copy</span>
              <span id="copyBtnText"><%= currentLang === 'es' ? 'Copiar Enlace de Conexión' : 'Copy Connection Link' %></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Premium Toast Notification Container -->
<div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 glass-panel border border-success/30 px-6 py-3 rounded-full flex items-center gap-2.5 opacity-0 pointer-events-none transition-all duration-300 shadow-2xl bg-success-container/20">
  <span class="material-symbols-outlined text-success">check_circle</span>
  <span class="text-sm font-bold text-on-surface" id="toastMsg">URL Copied!</span>
</div>

<script>
  function copyPublicUrl() {
    const url = "<%= bot.public_url || '' %>";
    navigator.clipboard.writeText(url).then(() => {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toastMsg');
      const copyBtnText = document.getElementById('copyBtnText');
      
      const isSpanish = "<%= currentLang %>" === "es";
      toastMsg.innerText = isSpanish ? "¡Enlace copiado al portapapeles!" : "Connection URL copied to clipboard!";
      
      // Feedback on button
      copyBtnText.innerText = isSpanish ? "¡Copiado!" : "Copied!";
      setTimeout(() => {
        copyBtnText.innerText = isSpanish ? "Copiar Enlace de Conexión" : "Copy Connection Link";
      }, 2000);

      // Trigger floating toast
      toast.classList.remove('opacity-0', 'pointer-events-none');
      toast.classList.add('translate-y-[-10px]');
      
      setTimeout(() => {
        toast.classList.add('opacity-0', 'pointer-events-none');
        toast.classList.remove('translate-y-[-10px]');
      }, 2500);
    });
  }
</script>

<%- include("partials/footer") %>
