<%- include("partials/header") %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<!-- Toast Notification -->
<div id="toast" class="toast hidden" role="alert" aria-live="polite"></div>

<div class="card">
  <div class="card-header">
    <h2><%= bot.service_name %></h2>
    <span class="badge badge-<%= bot.publish_status %>"><%= bot.publish_status %></span>
  </div>
  
  <div class="bot-details">
    <h3>Persona</h3>
    <p><strong>Name:</strong> <%= bot.persona_name %></p>
    <p><strong>Profession:</strong> <%= bot.persona_profession %></p>
    <p><strong>Description:</strong> <%= bot.persona_description %></p>
    
    <h3>Service</h3>
    <p><strong>Name:</strong> <%= bot.service_name %></p>
    <p><strong>Description:</strong> <%= bot.service_description %></p>
    <p><strong>Slug:</strong> <%= bot.slug %></p>
    
    <h3>AI Configuration</h3>
    <p><strong>Prompt:</strong> <%= bot.prompt %></p>
    <p><strong>RAG URLs:</strong> <%= bot.rag_urls?.join(", ") || "None" %></p>
    <p><strong>Premium Integrations:</strong> <%= (bot.mcp_servers?.length ? bot.mcp_servers.join(", ") : "None (default free tools active)") %></p>
    
    <% if (bot.public_url) { %>
    <div class="qr-container">
      <div style="text-align:center;">
        <h3 style="margin-top:0;">Your Agent is Live! ✨</h3>
        <p class="text-muted mb-4">Scan this code or share the link below to let clients chat with your agent.</p>
        <div id="qrcode" style="display:inline-block; margin-bottom: 1rem;"></div>
        <div>
          <input type="text" value="<%= bot.public_url %>" class="form-input" readonly style="width:300px; text-align:center;" />
        </div>
        <script>
          new QRCode(document.getElementById("qrcode"), {
            text: "<%= bot.public_url %>",
            width: 200,
            height: 200,
            colorDark : "#4F46E5",
            colorLight : "#ffffff"
          });
        </script>
      </div>
    </div>
    <% } %>
  </div>
  
  <div class="card-actions">
    <a href="/bots/<%= bot.id %>/edit" class="btn btn-secondary">✏️ Edit Settings</a>
    <% if (bot.publish_status === "draft" || bot.publish_status === "pending_apply") { %>
    <form action="/bots/<%= bot.id %>/publish" method="post" style="display:inline;" onsubmit="showLoader()">
      <button type="submit" class="btn btn-primary">🚀 Publish to the World</button>
    </form>
    <% } else { %>
    <form action="/bots/<%= bot.id %>/unpublish" method="post" style="display:inline;">
      <button type="submit" class="btn btn-secondary" style="color: #ef4444; border-color: #fca5a5;">🛑 Unpublish</button>
    </form>
    <% } %>
  </div>
</div>

<div id="publishModal" class="modal-backdrop hidden">
  <div class="card" style="text-align: center; max-width: 400px; margin: 0 auto;">
    <div class="loader mb-4"></div>
    <h3 style="margin-top: 0;">Deploying your AI Agent...</h3>
    <p class="text-muted">This may take a few moments. We are packing up your agent's skills and launching them to the Verana Network!</p>
  </div>
</div>

<style>
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: white;
    z-index: 9999;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateY(0);
    opacity: 1;
  }
  .toast.hidden { transform: translateY(80px); opacity: 0; pointer-events: none; }
  .toast.success { background: linear-gradient(135deg, #4F46E5, #7C3AED); }
  .toast.info { background: linear-gradient(135deg, #0ea5e9, #2563eb); }
</style>

<script>
  function showLoader() {
    document.getElementById('publishModal').classList.remove('hidden');
  }

  // Show toast based on URL query param
  (function() {
    const params = new URLSearchParams(window.location.search);
    const toastKey = params.get('toast');
    const toastEl = document.getElementById('toast');
    const messages = {
      published: { text: '🚀 Agent published successfully!', cls: 'success' },
      unpublished: { text: '🛑 Agent unpublished.', cls: 'info' }
    };
    if (toastKey && messages[toastKey]) {
      toastEl.textContent = messages[toastKey].text;
      toastEl.classList.add(messages[toastKey].cls);
      toastEl.classList.remove('hidden');
      // Clean the URL without reloading the page
      window.history.replaceState({}, '', window.location.pathname);
      setTimeout(() => toastEl.classList.add('hidden'), 3500);
    }
  })();
</script>

<%- include("partials/footer") %>