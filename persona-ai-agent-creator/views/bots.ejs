<%- include("partials/header") %>

<div class="card">
  <div class="card-header">
    <div>
      <h2 style="margin:0;"><%= t('bot.myBots') %></h2>
      <p class="text-muted text-sm"><%= t('bot.botsSubtitle') %></p>
    </div>
    <a href="/bots/new" class="btn btn-primary">+ <%= t('bot.createBot') %></a>
  </div>
</div>

<% if (!bots.length) { %>
<div class="card">
  <div class="empty-state">
    <h3 class="empty-title"><%= t('bot.noBotsYet') %></h3>
    <p class="empty-text"><%= t('bot.noBotsHint') %></p>
    <a href="/bots/new" class="btn btn-primary"><%= t('bot.createFirstBot') %></a>
  </div>
</div>
<% } else { %>
<div class="bot-grid">
  <% bots.forEach((bot) => { %>
  <article class="bot-card">
    <div class="bot-card-header">
      <h3 class="bot-card-title"><%= bot.service_name %></h3>
      <span class="badge badge-<%= bot.publish_status %>"><%= bot.publish_status %></span>
    </div>
    <div class="bot-card-body">
      <p class="bot-card-meta">👤 <%= bot.persona_name %></p>
      <p class="bot-card-meta text-xs text-muted"><%= t('bots.lastUpdated') %>: <%= new Date(bot.updated_at).toLocaleDateString() %></p>
    </div>
    <div class="bot-card-actions">
      <a href="/bots/<%= bot.id %>" class="btn btn-sm btn-secondary"><%= t('bot.manage') %></a>
      <% if (bot.public_url) { %>
      <a href="<%= bot.public_url %>" target="_blank" rel="noreferrer" class="btn btn-sm btn-primary"><%= t('common.open') %></a>
      <% } %>
    </div>
  </article>
  <% }) %>
</div>
<% } %>

<%- include("partials/footer") %>