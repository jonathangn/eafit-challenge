<%- include("partials/header") %>

<div class="relative py-20 px-margin-mobile">
    <!-- Abstract gradient blob -->
    <div class="absolute top-1/4 -right-1/4 w-[500px] h-[500px] rounded-full bg-primary/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-md w-full mx-auto relative z-10">
        <!-- Header -->
        <div class="text-center mb-10">
            <h2 class="font-headline-lg-mobile text-headline-lg-mobile mb-2 text-gradient-primary">
                <%= t('auth.forgotPasswordTitle') %>
            </h2>
            <p class="font-body-md text-body-md text-on-surface-variant">
                <%= t('auth.forgotPasswordSubtitle') %>
            </p>
        </div>

        <!-- Forgot Card -->
        <div class="glass-panel p-8 shadow-2xl">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-error/10 border border-error/20 text-error p-4 rounded-xl mb-6 text-sm flex gap-3 items-center">
                    <span class="material-symbols-outlined">error</span>
                    <%= error %>
                </div>
            <% } %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-primary/10 border border-primary/20 text-primary p-4 rounded-xl mb-6 text-sm flex flex-col gap-3 items-start">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        <%= success %>
                    </div>
                    <% if (typeof actionLink !== 'undefined' && actionLink) { %>
                    <a href="<%= actionLink %>" class="w-full btn-primary btn-base py-2 text-center font-bold text-on-primary flex items-center justify-center gap-2 mt-1">
                        <span class="material-symbols-outlined text-[18px]">lock_reset</span>
                        <%= t('auth.resetLinkBtn') %>
                    </a>
                    <% } %>
                </div>
            <% } %>

            <form action="/forgot-password" method="post" class="space-y-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                
                <%- include("partials/input", { 
                    name: "email", 
                    type: "email", 
                    icon: "mail", 
                    label: t('auth.emailLabel'), 
                    placeholder: t('auth.emailPlaceholder'), 
                    required: true, 
                    autocomplete: "email" 
                }) %>

                <button type="submit" id="forgot-submit" class="btn-primary btn-base w-full py-3 font-bold shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
                    <span id="forgot-submit-text"><%= t('auth.forgotPasswordSubmit') %></span>
                    <span id="forgot-submit-icon" class="material-symbols-outlined">send</span>
                </button>
                <script>
                    document.querySelector('form[action="/forgot-password"]')?.addEventListener('submit', function() {
                        const b = document.getElementById('forgot-submit');
                        b.disabled = true;
                        b.classList.add('opacity-50', 'pointer-events-none');
                        document.getElementById('forgot-submit-text').textContent = '<%= t('common.loading') %>';
                        document.getElementById('forgot-submit-icon').textContent = 'sync';
                        document.getElementById('forgot-submit-icon').classList.add('animate-spin');
                    });
                </script>
            </form>

            <div class="mt-8 pt-6 border-t border-outline/10 text-center">
                <p class="font-body-md text-body-md text-on-surface-variant">
                    <a href="/login" class="text-primary font-bold hover:underline inline-flex items-center gap-1">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                        <%= t('auth.signInLink') %>
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<%- include("partials/footer") %>
