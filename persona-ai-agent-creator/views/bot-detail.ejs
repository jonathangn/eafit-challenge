<%- include("partials/header") %>

<div class="card mb-4">
  <div class="card-header">
    <div>
      <h2 style="margin:0;"><%= bot.service_name %></h2>
      <p class="text-muted text-sm">👤 <%= bot.persona_name %> · <span class="badge badge-<%= bot.publish_status %>"><%= t("bot.status") %></span></p>
    </div>
    <div class="flex gap-2">
      <a href="/bots/<%= bot.id %>/edit" class="btn btn-secondary"><%= t("common.edit") %></a>
      <form action="/bots/<%= bot.id %>/publish" method="post">
        <button type="submit" class="btn btn-primary" <%= bot.publish_status === 'published' ? 'disabled' : '' %>>
          <%= bot.publish_status === 'published' ? t("bot.published") : t("bot.publish") %>
        </button>
      </form>
    </div>
  </div>
</div>

<% if (bot.public_url) { %>
<div class="card mb-4">
  <h3 class="section-title"><%= t("bot.publicUrl") %></h3>
  <div class="flex items-center gap-3">
    <code class="flex-1 p-3 bg-muted rounded"><%= bot.public_url %></code>
    <a href="<%= bot.public_url %>" target="_blank" rel="noreferrer" class="btn btn-secondary"><%= t("common.open") %></a>
  </div>
</div>
<% } %>

<div class="grid-2 mb-4">
  <div class="card">
    <h3 class="section-title"><%= t("bot.persona") %></h3>
    <dl class="dl">
      <dt><%= t("common.name") %></dt><dd><%= bot.persona_name %></dd>
      <dt><%= t("bot.profession") %></dt><dd><%= bot.persona_profession %></dd>
      <dt><%= t("common.description") %></dt><dd><%= bot.persona_description || '-' %></dd>
      <% if (bot.persona_photo_url) { %>
      <dt>Photo</dt><dd><img src="<%= bot.persona_photo_url %>" alt="<%= bot.persona_name %>" class="avatar-sm" /></dd>
      <% } %>
    </dl>
  </div>
  
  <div class="card">
    <h3 class="section-title"><%= t("bot.service") %></h3>
    <dl class="dl">
      <dt><%= t("common.name") %></dt><dd><%= bot.service_name %></dd>
      <dt><%= t("bot.category") %></dt><dd><%= bot.service_category %></dd>
      <dt><%= t("common.description") %></dt><dd><%= bot.service_description || '-' %></dd>
    </dl>
  </div>
</div>

<div class="card mb-4">
  <h3 class="section-title"><%= t("bot.instructions") %></h3>
  <pre class="code-block"><%= bot.prompt %></pre>
</div>

<% if (bot.mcp_servers && bot.mcp_servers.length) { %>
<div class="card mb-4">
  <h3 class="section-title"><%= t("bot.mcpIntegrations") %></h3>
  <div class="flex gap-2 flex-wrap">
    <% bot.mcp_servers.forEach(mcp => { %>
    <span class="badge badge-info"><%= mcp %></span>
    <% }) %>
  </div>
</div>
<% } %>

<% if (bot.rag_urls && bot.rag_urls.length) { %>
<div class="card mb-4">
  <h3 class="section-title"><%= t("bot.knowledgeBase") %></h3>
  <ul class="list-disc pl-5">
    <% bot.rag_urls.forEach(url => { %>
    <li><a href="<%= url %>" target="_blank" rel="noreferrer" class="link"><%= url %></a></li>
    <% }) %>
  </ul>
</div>
<% } %>

<div class="card">
  <div class="card-header">
    <h3 class="section-title mb-0"><%= t("bot.recentRuns") %></h3>
  </div>
  <% if (!runs.length) { %>
  <p class="text-muted p-4 text-center"><%= t("bot.noRunsYet") %></p>
  <% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th><%= t("common.id") %></th>
        <th><%= t("common.status") %></th>
        <th><%= t("bot.started") %></th>
        <th><%= t("bot.duration") %></th>
      </tr>
    </thead>
    <tbody>
      <% runs.forEach(run => { %>
      <tr>
        <td><code class="text-xs"><%= run.id.slice(0,8) %></code></td>
        <td><span class="badge badge-<%= run.status %>"><%= run.status %></span></td>
        <td><%= new Date(run.started_at).toLocaleString() %></td>
        <td><%= run.completed_at ? Math.round((new Date(run.completed_at) - new Date(run.started_at))/1000) + 's' : '-' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include("partials/footer") %>