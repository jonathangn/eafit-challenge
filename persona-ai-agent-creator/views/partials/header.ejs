<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <meta name="robots" content="index, follow" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    
    <%
      const pageTitle = typeof title !== 'undefined' ? `${title} | Persona Studio` : t('common.title');
      const pageDesc = typeof description !== 'undefined' ? description : t('common.description');
      const pageUrl = typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://persona.team-f.teams.eafit.testnet.verana.network' + (typeof req !== 'undefined' ? req.originalUrl : '');
      const pageImage = (typeof image !== 'undefined' && image)
        ? (image.startsWith('http') ? image : 'https://persona.team-f.teams.eafit.testnet.verana.network' + image)
        : 'https://persona.team-f.teams.eafit.testnet.verana.network/og-image.png';
    %>
    
    <title><%= pageTitle %></title>
    <meta name="description" content="<%= pageDesc %>" />
    <link rel="canonical" href="<%= pageUrl %>" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="<%= pageUrl %>" />
    <meta property="og:title" content="<%= pageTitle %>" />
    <meta property="og:description" content="<%= pageDesc %>" />
    <meta property="og:image" content="<%= pageImage %>" />
    <meta property="og:locale" content="<%= currentLang === 'es' ? 'es_ES' : 'en_US' %>" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="<%= pageUrl %>" />
    <meta property="twitter:title" content="<%= pageTitle %>" />
    <meta property="twitter:description" content="<%= pageDesc %>" />
    <meta property="twitter:image" content="<%= pageImage %>" />
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- High-Performance Asynchronous Web Font Loading -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700&display=swap" rel="stylesheet" />
    </noscript>
    
    <!-- Render-safe Material Icons with blocked display to prevent unstyled text flashes (FOUT) -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    </noscript>
    
    <link rel="manifest" href="/manifest.json" />
    <script>
      // Service Worker Registration for PWA
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then(reg => console.log('ServiceWorker registered with scope:', reg.scope))
            .catch(err => console.error('ServiceWorker registration failed:', err));
        });
      }
    </script>

    <% if (typeof inlineCss !== 'undefined' && inlineCss) { %>
      <style><%- inlineCss %></style>
    <% } else { %>
      <link rel="stylesheet" href="/css/output.css?v=<%= assetVersion %>" />
    <% } %>
    <script>
      // Persistent Theme Logic - Auto-detect system preference if not set
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      function toggleTheme() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }
      // Default no-op for pages without wizard form
      window.saveWizardState = () => true;
    </script>

    <!-- Structured Data (Schema.org) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Persona Studio",
      "description": "Create and manage AI persona agents with custom skills, knowledge, and MCP integrations",
      "url": "https://persona.team-f.teams.eafit.testnet.verana.network",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "inLanguage": "<%= currentLang === 'es' ? 'es' : 'en' %>"
    }
    </script>

</head>
<body class="text-on-background min-h-screen overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container" style="background: var(--bg-gradient); background-attachment: fixed;">
    <header class="glass-bar sticky top-0 z-50 w-full">
        <div class="flex justify-between items-center px-margin-mobile h-24 max-w-container-max mx-auto">
        <div class="flex items-center gap-4">
            <a href="/" class="font-headline-md text-headline-md font-bold text-gradient-primary">
                <%= t('common.logoText') %>
            </a>
        </div>
        
        <nav class="flex items-center gap-base">
            <% if (currentUser) { %>
                <a href="/bots" class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg hover:bg-surface-container-highest/50 transition-colors font-label-md text-label-md hover:text-primary" style="color: var(--on-surface);">
                    <span class="material-symbols-outlined">smart_toy</span>
                    <%= t('nav.myAgents') %>
                </a>
                <form action="/logout" method="post" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg hover:bg-surface-container-highest/50 transition-colors font-label-md text-label-md hover:text-primary" style="color: var(--on-surface);">
                        <span class="material-symbols-outlined">logout</span>
                        <%= t('nav.logout') %>
                    </button>
                </form>
            <% } else { %>
                <a href="/login" class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg hover:bg-surface-container-highest/50 transition-colors font-label-md text-label-md hover:text-primary" style="color: var(--on-surface);">
                    <span class="material-symbols-outlined">login</span>
                    <%= t('nav.login') %>
                </a>
                <a href="/register" class="btn-primary btn-base px-6 py-2 rounded-full font-bold shadow-lg shadow-primary/20" style="color: var(--on-primary);">
                    <%= t('nav.register') %>
                </a>
            <% } %>

            <!-- Language Toggle -->
            <div class="flex items-center bg-surface-container-low border border-outline/30 rounded-full overflow-hidden ml-2">
                <a href="/set-lang/en" onclick="return saveWizardState()" class="px-3 py-1.5 text-xs font-bold transition-colors <%= currentLang === 'en' ? 'bg-gradient-primary' : 'hover:bg-surface-container-highest/50' %>" style="color: <%= currentLang === 'en' ? 'var(--on-primary)' : 'var(--on-surface)' %>;">
                    EN
                </a>
                <a href="/set-lang/es" onclick="return saveWizardState()" class="px-3 py-1.5 text-xs font-bold transition-colors <%= currentLang === 'es' ? 'bg-gradient-primary' : 'hover:bg-surface-container-highest/50' %>" style="color: <%= currentLang === 'es' ? 'var(--on-primary)' : 'var(--on-surface)' %>;">
                    ES
                </a>
            </div>

            <!-- Theme Toggle -->
            <button onclick="toggleTheme()" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-surface-container-highest/50 transition-colors" style="color: var(--on-surface);" aria-label="Toggle theme">
                <span class="material-symbols-outlined dark:hidden" aria-hidden="true">dark_mode</span>
                <span class="material-symbols-outlined hidden dark:inline" aria-hidden="true">light_mode</span>
            </button>
        </nav>
        </div>
    </header>

    <main class="max-w-container-max mx-auto">