<%- include("partials/header") %>

<div class="creator-layout">
  <div class="card">
  <h2 style="margin:0 0 var(--space-2);"><%= submitLabel %></h2>
  <p class="text-muted mb-4"><%= t("form.intro") %></p>
  
  <% if (error) { %>
  <div class="form-error"><%= error %></div>
  <% } %>
  
  <div class="stepper">
    <div class="step active" data-step-indicator="1">1. <%= t("form.step1") %></div>
    <div class="step" data-step-indicator="2">2. <%= t("form.step2") %></div>
    <div class="step" data-step-indicator="3">3. <%= t("form.step3") %></div>
    <div class="step" data-step-indicator="4">4. <%= t("form.step4") %></div>
  </div>
  
  <form id="botForm" action="<%= formAction %>" method="post" enctype="multipart/form-data" onsubmit="console.log('Form submit blocked by HTML'); return false;">
    <div class="wizard-step" data-step="1">
      <h3 class="section-title">Start with a Template (Optional)</h3>
      <div class="template-cards">
        <div class="template-card" onclick="applyTemplate('plumber')">
          <div class="template-icon">🔧</div>
          <div style="font-weight: 500">Plumber</div>
        </div>
        <div class="template-card" onclick="applyTemplate('tutor')">
          <div class="template-icon">👨‍🏫</div>
          <div style="font-weight: 500">Tutor</div>
        </div>
        <div class="template-card" onclick="applyTemplate('consultant')">
          <div class="template-icon">💼</div>
          <div style="font-weight: 500">Consultant</div>
        </div>
      </div>

      <h3 class="section-title mt-6">Agent Identity</h3>
      
      <div class="form-group">
        <label class="form-label">Agent Name</label>
        <input type="text" id="personaName" name="personaName" class="form-input" value="<%= bot.personaName || bot.persona_name || '' %>" required oninput="updateMockup()" />
        <p class="form-hint">What is your agent's name?</p>
      </div>
      
      <div class="form-group">
        <label class="form-label">Profession / Role</label>
        <input type="text" id="personaProfession" name="personaProfession" class="form-input" value="<%= bot.personaProfession || bot.persona_profession || '' %>" required oninput="updateMockup()" />
        <p class="form-hint">e.g., Plumber, English Tutor, Tax Consultant</p>
      </div>
      
      <div class="form-group">
        <label class="form-label">Short Tagline</label>
        <textarea name="personaDescription" class="form-input" rows="3"><%= bot.personaDescription || bot.persona_description || '' %></textarea>
      </div>
      
      <div class="form-group">
        <label class="form-label">Profile Photo URL (Optional)</label>
        <input type="url" id="personaPhotoUrl" name="personaPhotoUrl" class="form-input" value="<%= bot.personaPhotoUrl || bot.persona_photo_url || '' %>" placeholder="https://..." oninput="updateMockup()" />
      </div>
      
      <div class="form-group">
        <label class="form-label"><%= t("form.uploadPhoto") %></label>
        <input type="file" name="photo" class="form-input" accept="image/*" />
      </div>
    </div>

    <div class="wizard-step hidden" data-step="2">
      <h3 class="section-title"><%= t("form.serviceTitle") %></h3>
      
      <div class="form-group">
        <label class="form-label"><%= t("form.serviceName") %></label>
        <input type="text" name="serviceName" class="form-input" value="<%= bot.serviceName || bot.service_name || '' %>" required />
        <p class="form-hint"><%= t("form.serviceNameHint") %></p>
      </div>
      
      <div class="form-group">
        <label class="form-label"><%= t("form.category") %></label>
        <input type="text" name="serviceCategory" class="form-input" value="<%= bot.serviceCategory || bot.service_category || '' %>" required />
        <p class="form-hint"><%= t("form.categoryHint") %></p>
      </div>
      
      <div class="form-group">
        <label class="form-label"><%= t("form.serviceDescription") %></label>
        <textarea name="serviceDescription" class="form-input" rows="3"><%= bot.serviceDescription || bot.service_description || '' %></textarea>
      </div>
    </div>

    <div class="wizard-step hidden" data-step="3">
      <h3 class="section-title">Agent Personality & Instructions</h3>
      <p class="text-muted mb-4">How should your agent talk to your clients? What rules should it follow?</p>
      
      <div class="form-group">
        <label class="form-label">Instructions</label>
        <textarea id="prompt" name="prompt" class="form-input" rows="10" required><%= bot.prompt || '' %></textarea>
        <p class="form-hint">Be clear and specific. Tell the agent exactly what its job is.</p>
      </div>
    </div>

    <div class="wizard-step hidden" data-step="4">
      <h3 class="section-title">Premium Integrations</h3>
      <p class="text-muted mb-4">Connect external accounts to give your agent advanced capabilities.</p>

      <div class="integrations-container" style="display: flex; flex-direction: column; gap: 1rem;">
        <% 
        const groupedCatalog = {
          "Developer": mcpCatalog.filter(c => c.profile === 'Developer'),
          "Executive": mcpCatalog.filter(c => c.profile === 'Executive')
        };
        %>
        
        <% Object.keys(groupedCatalog).forEach(profileName => { %>
          <div class="profile-group">
            <h4 style="font-weight: 600; margin-bottom: 0.75rem; color: var(--text-muted);"><%= profileName %> Integrations</h4>
            <div class="checkbox-grid">
              <% groupedCatalog[profileName].forEach((mcp) => { %>
              <label class="skill-card <%= (bot.mcpServers || []).includes(mcp.id) ? 'selected' : '' %>">
                <input
                  type="checkbox"
                  name="mcpServers"
                  value="<%= mcp.id %>"
                  <%= (bot.mcpServers || []).includes(mcp.id) ? 'checked' : '' %>
                  onchange="this.parentElement.classList.toggle('selected', this.checked)"
                />
                <div class="skill-icon"><%= mcp.icon %></div>
                <div class="skill-content">
                  <div class="skill-title"><%= t(mcp.nameKey) %></div>
                  <div class="skill-desc"><%= t(mcp.descriptionKey) %></div>
                </div>
              </label>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>

      <h3 class="section-title mt-6">Knowledge Base</h3>
      <p class="text-muted mb-4">Paste links to your website or menus so your agent can learn from them.</p>
      <div class="form-group">
        <label class="form-label">URLs (one per line)</label>
        <textarea name="ragUrls" class="form-input" rows="4" placeholder="https://mywebsite.com/about&#10;https://mywebsite.com/pricing"><%= (bot.ragUrls || []).join('\n') %></textarea>
      </div>
    </div>

    <div class="flex gap-3 mt-6">
      <button type="button" id="backBtn" class="btn btn-secondary"><%= t("common.back") %></button>
      <button type="button" id="nextBtn" class="btn btn-primary"><%= t("common.continue") %></button>
      <button type="submit" id="submitBtn" class="btn btn-primary hidden"><%= submitLabel %></button>
    </div>
  </form>
  </div> <!-- .card -->

  <div class="mobile-mockup">
    <div class="mobile-notch"></div>
    <div class="mobile-header">
      <div class="mobile-avatar" id="mockAvatar"></div>
      <div class="mobile-name" id="mockName">Your Agent Name</div>
      <div class="mobile-profession" id="mockProfession">Profession</div>
    </div>
    <div class="mobile-chat">
      <div class="chat-bubble">Hello! How can I help you today?</div>
      <div class="chat-bubble chat-bubble-user">I'd like to ask a question about your services.</div>
      <div class="chat-bubble">Of course! I'm an AI assistant acting on behalf of <span id="mockNameRef">this professional</span>. What would you like to know?</div>
    </div>
  </div>
</div> <!-- .creator-layout -->

    <script>
    (() => {
      const steps = Array.from(document.querySelectorAll(".wizard-step"));
      const indicators = Array.from(document.querySelectorAll("[data-step-indicator]"));
      const backBtn = document.getElementById("backBtn");
      const nextBtn = document.getElementById("nextBtn");
      const submitBtn = document.getElementById("submitBtn");
      let current = 1;
      
      const sync = () => {
        steps.forEach((el) => el.classList.toggle("hidden", Number(el.dataset.step) !== current));
        indicators.forEach((el) => {
          el.classList.toggle("active", Number(el.dataset.stepIndicator) === current);
        });
        backBtn.classList.toggle("hidden", current === 1);
        nextBtn.classList.toggle("hidden", current === steps.length);
        submitBtn.classList.toggle("hidden", current !== steps.length);
      };
      
      backBtn?.addEventListener("click", () => {
        current = Math.max(1, current - 1);
        sync();
      });
      nextBtn?.addEventListener("click", () => {
        current = Math.min(steps.length, current + 1);
        sync();
      });
      
      // Submit button triggers form submission explicitly
      submitBtn?.addEventListener("click", () => {
        console.log('Submit button clicked');
        const form = document.getElementById('botForm');
        if (form) {
          form.submit();
        }
      });
      
      sync();
    })();

    // Expose functions globally for HTML event handlers
    window.updateMockup = function() {
      const name = document.getElementById("personaName").value || "Your Agent Name";
      const profession = document.getElementById("personaProfession").value || "Profession";
      const photoUrl = document.getElementById("personaPhotoUrl").value;

      document.getElementById("mockName").innerText = name;
      document.getElementById("mockNameRef").innerText = name;
      document.getElementById("mockProfession").innerText = profession;

      const avatar = document.getElementById("mockAvatar");
      if (photoUrl) {
        avatar.style.backgroundImage = `url('${photoUrl}')`;
      } else {
        avatar.style.backgroundImage = 'none';
      }
    };

    window.applyTemplate = function(type) {
      let name = '', prof = '', prompt = '';
      if (type === 'plumber') {
        name = 'Mario'; prof = 'Master Plumber';
        prompt = 'You are Mario, an expert plumber with 20 years of experience. Be helpful, clear, and diagnose issues step by step.';
      } else if (type === 'tutor') {
        name = 'Sarah'; prof = 'English Tutor';
        prompt = 'You are Sarah, a patient and encouraging English tutor. Help correct grammar gently and provide examples.';
      } else if (type === 'consultant') {
        name = 'James'; prof = 'Business Consultant';
        prompt = 'You are James, a sharp and professional business consultant. Focus on ROI, strategy, and clear action items.';
      }

      document.getElementById("personaName").value = name;
      document.getElementById("personaProfession").value = prof;
      document.getElementById("prompt").value = prompt;
      updateMockup();

      // Show typing animation
      const chatContainer = document.querySelector('.mobile-chat');
      const typingBubble = document.createElement('div');
      typingBubble.className = 'typing-indicator';
      typingBubble.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
      chatContainer.appendChild(typingBubble);
      
      // Remove typing bubble after 1.5 seconds
      setTimeout(() => {
        if(chatContainer.contains(typingBubble)) {
          chatContainer.removeChild(typingBubble);
        }
      }, 1500);
    };

    // Initialize mockup on load
    window.addEventListener("DOMContentLoaded", () => {
      window.updateMockup();
    });
  </script>

<%- include("partials/footer") %>