PORT=3000
JWT_SECRET=your_jwt_secret

# --- Storage Paths ---
DATABASE_PATH=./data/app.db
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# --- Kubernetes & Deployment Setup ---
TEAM_NAMESPACE=your_namespace
BASE_DOMAIN=your_custom_domain.com
KUBECONFIG_PATH=/path/to/your/kubeconfig.yaml
KUBECTL_BIN=/usr/local/bin/kubectl
ENABLE_K8S_APPLY=false
AGENT_IMAGE=your_docker_repo/your_agent_image:latest

# --- OAuth Config (Optional) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- SMTP Config (Local Environment) ---
LOCAL_SMTP_HOST=your_local_smtp_host
LOCAL_SMTP_PORT=2525
LOCAL_SMTP_SECURE=false
LOCAL_SMTP_USER=your_local_smtp_user
LOCAL_SMTP_PASS=your_local_smtp_pass

# --- SMTP Config (Production Environment) ---
PROD_SMTP_HOST=your_prod_smtp_host
PROD_SMTP_PORT=465
PROD_SMTP_SECURE=true
PROD_SMTP_USER=your_prod_smtp_user
PROD_SMTP_PASS=your_prod_smtp_pass

EMAIL_FROM="Your App Name <noreply@yourdomain.com>"
